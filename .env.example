# =============================================================================
# Distributed Job Scheduler — Environment Configuration
# Copy to .env and fill in your values. Never commit .env to version control.
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8080
APP_BASE_URL=http://localhost:8080

# ─── JWT Authentication ───────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-at-least-64-chars
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=scheduler
POSTGRES_PASSWORD=scheduler_secret
POSTGRES_DB=job_scheduler
POSTGRES_SSL_MODE=disable
POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_CONN_MAX_LIFETIME=5m

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_POOL_SIZE=10

# ─── Worker ───────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=10
WORKER_POLL_INTERVAL=1s
WORKER_HEARTBEAT_INTERVAL=5s
WORKER_HEARTBEAT_TIMEOUT=30s
WORKER_VISIBILITY_TIMEOUT=5m
WORKER_DRAIN_TIMEOUT=60s
WORKER_MAX_BATCH_SIZE=10

# ─── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULER_TICK_INTERVAL=1s
SCHEDULER_CRON_LOCK_TTL=55s

# ─── Metrics ─────────────────────────────────────────────────────────────────
METRICS_FLUSH_INTERVAL=60s

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MIN=120
